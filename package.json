{
  "name": "forge",
  "version": "0.1.0",
  "description": "Autonomous software development orchestrator built on the Claude Agent SDK",
  "type": "module",
  "bin": {
    "forge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir test/integration",
    "test:scenarios": "vitest run --dir test/scenarios",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shootdaj/forge.git"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "claude",
    "autonomous"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shootdaj/forge/issues"
  },
  "homepage": "https://github.com/shootdaj/forge#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.69",
    "commander": "^14.0.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
